# Local production-like smoke env (NOT for real VPS deploy).
# Reuses dev PostgreSQL credentials so existing docker volumes keep working.

APP_NAME=B2B LeadFlow Agent
APP_VERSION=0.9.0-stage8
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
ALLOW_INSECURE_LOCAL_PRODUCTION_SMOKE=true

SYSTEM_STOP_ALL=true

REAL_EMAIL_PROVIDER_ENABLED=false
LIVE_OUTREACH_ENABLED=false
PROVIDER_API_KEY=
PROVIDER_SENDER_EMAIL=
PROVIDER_SENDER_DOMAIN=
PROVIDER_DAILY_LIMIT=0

LIVE_PILOT_DATABASE_GATE=false
LIVE_PROVIDER_NAME=
LIVE_PROVIDER_API_KEY=
LIVE_SENDER_EMAIL=
LIVE_SENDER_DOMAIN=
LIVE_DAILY_LIMIT=0
LIVE_RATE_LIMIT_PER_MINUTE=0
LIVE_PILOT_MAX_RECIPIENTS=1

POSTGRES_USER=leadflow
POSTGRES_PASSWORD=leadflow_dev_password
POSTGRES_DB=leadflow
DATABASE_URL=postgresql://leadflow:leadflow_dev_password@postgres:5432/leadflow

REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGIN=http://127.0.0.1:8080
PROXY_HTTP_PORT=8080
