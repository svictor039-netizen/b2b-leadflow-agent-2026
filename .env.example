# B2B LeadFlow Agent — environment template (stage 0)
# Copy to .env and adjust locally. Never commit .env to git.

# Application
APP_NAME=B2B LeadFlow Agent
APP_VERSION=0.3.0-stage2
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Emergency stop — blocks all outbound email tasks when true
SYSTEM_STOP_ALL=false

# Database (dev defaults — change in production)
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=leadflow_dev_password
POSTGRES_DB=leadflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql://leadflow:leadflow_dev_password@postgres:5432/leadflow

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery (defaults to REDIS_URL if unset)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:8080
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Skip integration tests locally when postgres/redis unavailable
# SKIP_INTEGRATION=1
