# B2B LeadFlow Agent — environment template (stage 0)
# Copy to .env and adjust locally. Never commit .env to git.

# Application
APP_NAME=B2B LeadFlow Agent
APP_VERSION=0.4.0-stage3
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Emergency stop — blocks all outbound email tasks when true
SYSTEM_STOP_ALL=false

# Stage 6 — provider readiness placeholders (keep disabled; never put production secrets here)
REAL_EMAIL_PROVIDER_ENABLED=false
LIVE_OUTREACH_ENABLED=false
PROVIDER_API_KEY=
PROVIDER_SENDER_EMAIL=
PROVIDER_SENDER_DOMAIN=
PROVIDER_DAILY_LIMIT=0

# Stage 7A — controlled live pilot (keep disabled; never put production secrets here)
LIVE_PILOT_DATABASE_GATE=false
LIVE_PROVIDER_NAME=
LIVE_PROVIDER_API_KEY=
LIVE_SENDER_EMAIL=
LIVE_SENDER_DOMAIN=
LIVE_DAILY_LIMIT=0
LIVE_RATE_LIMIT_PER_MINUTE=0
LIVE_PILOT_MAX_RECIPIENTS=1

# Database (dev defaults — change in production)
POSTGRES_USER=leadflow
POSTGRES_PASSWORD=leadflow_dev_password
POSTGRES_DB=leadflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql://leadflow:leadflow_dev_password@postgres:5432/leadflow

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery (defaults to REDIS_URL if unset)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:8080
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Skip integration tests locally when postgres/redis unavailable
# SKIP_INTEGRATION=1
