# B2B LeadFlow Agent — production template (Stage 8)
# Copy to .env.production on VPS. NEVER commit real secrets or .env.production to git.
# Default posture: STOPPED — no live email, no outbound sends.

# Application
APP_NAME=B2B LeadFlow Agent
APP_VERSION=0.9.0-stage8
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Emergency stop — MUST remain true until explicit operator review after deploy
SYSTEM_STOP_ALL=true

# Stage 6 — keep disabled (placeholders only)
REAL_EMAIL_PROVIDER_ENABLED=false
LIVE_OUTREACH_ENABLED=false
PROVIDER_API_KEY=
PROVIDER_SENDER_EMAIL=
PROVIDER_SENDER_DOMAIN=
PROVIDER_DAILY_LIMIT=0

# Stage 7A — controlled live pilot (keep disabled; no real credentials)
LIVE_PILOT_DATABASE_GATE=false
LIVE_PROVIDER_NAME=
LIVE_PROVIDER_API_KEY=
LIVE_SENDER_EMAIL=
LIVE_SENDER_DOMAIN=
LIVE_DAILY_LIMIT=0
LIVE_RATE_LIMIT_PER_MINUTE=0
LIVE_PILOT_MAX_RECIPIENTS=1

# PostgreSQL — replace ALL placeholders before deploy
POSTGRES_USER=CHANGE_ME_PROD_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=leadflow
DATABASE_URL=postgresql://CHANGE_ME_PROD_USER:CHANGE_ME_STRONG_PASSWORD@postgres:5432/leadflow

# Redis — no password in example; set strong auth on VPS if exposed internally
REDIS_URL=redis://redis:6379/0

# Celery (defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS — production domain only (no localhost)
FRONTEND_ORIGIN=https://app.example.com

# Docker prod ports (proxy only published externally)
PROXY_HTTP_PORT=8080
